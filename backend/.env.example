# Server
HOST=0.0.0.0
PORT=5000
DEBUG=false

# Security
SECRET_KEY=change-me-to-a-long-random-secret
JWT_SECRET=change-me-to-a-different-long-random-secret
JWT_EXPIRY_DAYS=30

# Optional admin bootstrap for a brand-new deploy.
# Set these once, log in, then remove BOOTSTRAP_ADMIN_PASSWORD from your host secrets.
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# CORS
# Leave empty when the frontend is served by this same backend.
# If frontend and backend are on different domains, add the frontend origin(s), comma-separated.
CORS_ALLOWED_ORIGINS=

# Database (legacy/local settings)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=studybot_db
DB_POOL_SIZE=10
DB_CONNECT_TIMEOUT=10

# Firebase (Firestore)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Local path option for development:
FIREBASE_SERVICE_ACCOUNT_JSON=
# Hosted deployment option: paste the full JSON on one line as a secret.
FIREBASE_SERVICE_ACCOUNT_JSON_RAW=

# AI
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
AI_DAILY_REQUEST_LIMIT=40
AI_COOLDOWN_SECONDS=2
AI_QUOTA_BLOCK_SECONDS=60
AI_FALLBACK_MODE=links

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
GOOGLE_ALLOWED_REDIRECTS=http://localhost:5000/auth/google/callback,http://127.0.0.1:5000/auth/google/callback

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

# Uploads
MAX_UPLOAD_MB=50
# UPLOAD_FOLDER=E:/StudyBot/backend/uploads
