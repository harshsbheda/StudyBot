# Server
HOST=0.0.0.0
PORT=5000
DEBUG=false

# Security (change in production)
SECRET_KEY=studybot-xyz-2024-abc
JWT_SECRET=studybot-super-secret-jwt-key-2024-xyz987
JWT_EXPIRY_DAYS=30

# MySQL (XAMPP defaults)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=studybot_db
DB_POOL_SIZE=10
DB_CONNECT_TIMEOUT=10

# AI (optional but recommended)
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
AI_DAILY_REQUEST_LIMIT=40
AI_COOLDOWN_SECONDS=2
AI_QUOTA_BLOCK_SECONDS=60
AI_FALLBACK_MODE=links

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
GOOGLE_ALLOWED_REDIRECTS=http://localhost:5000/auth/google/callback,http://127.0.0.1:5000/auth/google/callback

# Uploads
MAX_UPLOAD_MB=50
# UPLOAD_FOLDER=E:/StudyBot/backend/uploads
